# Demo configuration for the Medical SCADA course project.
# Copy this file to .env before running. Values below are demo-only placeholders.

# Backend server
PORT=3000
HOST=0.0.0.0
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.91:5173
JWT_SECRET=demo-change-this-jwt-secret
JWT_EXPIRES_IN=8h

# Demo-only API key for ESP32 fingerprint module. Keep this in sync with firmware/config portal.
ESP32_API_KEY=esp32-fingerprint-secret-change-me

# Demo-only API key for ESP32 cabin sensor. Keep this in sync with esp32_cabin_sensor.ino.
SENSOR_API_KEY=esp32-sensor-secret-change-me

# Frontend API endpoint (optional override)
# Leave blank when using Vite proxy. Example when backend runs on another machine:
# VITE_API_BASE_URL=http://192.168.1.10:3000/api
VITE_API_BASE_URL=
VITE_SOCKET_URL=

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/robot_ui?schema=public

# OPC UA Kepware Endpoint
OPCUA_ENDPOINT=opc.tcp://127.0.0.1:49320

# Keep true while hardware/PLC is not connected. Set to false before running with real PLC feedback.
VITE_SIMULATION_MODE=true
