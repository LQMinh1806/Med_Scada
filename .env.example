# Backend server
PORT=3000
HOST=0.0.0.0
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.91:5173
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=8h

# Security Key for ESP32 Fingerprint Module Communication
ESP32_API_KEY=my-super-secret-esp32-key-123

# Frontend API endpoint (optional override)
# Example when backend runs on another machine:
# VITE_API_BASE_URL=http://192.168.1.10:3000/api
VITE_API_BASE_URL=

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/robot_ui?schema=public
