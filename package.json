{
  "name": "robot-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n BE,FE -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:full": "npm run db:up && npx wait-on tcp:127.0.0.1:5432 && npm run dev",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "server": "npm run start -w backend",
    "server:dev": "npm run dev -w backend",
    "db:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "db:up:docker": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^6.17.1",
    "wait-on": "^8.0.5"
  }
}
